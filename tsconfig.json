{
  "compilerOptions": {

    "target": "es6",
    "lib": ["es5", "es6", "dom"],
    "module": "commonjs",
    "rootDir": "./src",
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "@logic/*": ["logic/*"],
      "@resources/*": ["resources/*"]
    },
    "typeRoots": ["./src/types", "./node_modules/@types"],
    "types": ["node"],
    "allowJs": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
